# =============================================================================
# Emoticon Web — 환경 변수 참고 (루트)
# 실제 secret 값은 커밋하지 마세요. placeholder·localhost만 사용합니다.
# =============================================================================
#
# 로컬 설정 (권장):
#   cp frontend/.env.example frontend/.env   # VITE_* · publishable key만
#   cp backend/.env.example backend/.env   # SUPABASE_SECRET_KEY 포함
#
# 템플릿 파일 (커밋 대상):
#   frontend/.env.example
#   backend/.env.example
#   .env.example (이 파일, 참고용)
#
# Supabase Dashboard → Project Settings → API
#   Project URL        → VITE_SUPABASE_URL / SUPABASE_URL
#   Publishable key    → VITE_SUPABASE_PUBLISHABLE_KEY / SUPABASE_PUBLISHABLE_KEY
#   Secret key         → SUPABASE_SECRET_KEY (backend/.env 전용, 프론트·VITE_* 금지)
#
# 상세: docs/04-security/api-key-policy.md
#
# =============================================================================

NODE_ENV=development

FRONTEND_PORT=5173
BACKEND_PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend → frontend/.env.example 참고
# -----------------------------------------------------------------------------
# VITE_API_BASE_URL=http://localhost:4000
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# -----------------------------------------------------------------------------
# Backend → backend/.env.example 참고
# -----------------------------------------------------------------------------
# PORT=4000
# FRONTEND_ORIGIN=http://localhost:5173
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# SUPABASE_SECRET_KEY=your-supabase-secret-key
