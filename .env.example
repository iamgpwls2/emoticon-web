# =============================================================================
# Emoticon Web — 환경 변수 템플릿 (Day 1)
# 실제 secret 값은 커밋하지 마세요. placeholder·localhost만 사용합니다.
# =============================================================================
#
# 복사 방법
#   frontend/.env  ← 아래 "Frontend" 섹션 (VITE_* 만)
#   backend/.env   ← 아래 "Backend" 섹션 (SUPABASE_SECRET_KEY 포함)
#   .env           ← 선택, 루트 참고용 (cp .env.example .env)
#
# Supabase Dashboard → Project Settings → API
#   Project URL        → VITE_SUPABASE_URL / SUPABASE_URL
#   Anon key           → VITE_SUPABASE_ANON_KEY (frontend/.env 전용)
#   Publishable key    → SUPABASE_PUBLISHABLE_KEY (backend/.env)
#   Secret key         → SUPABASE_SECRET_KEY (backend/.env 전용, 프론트·VITE_* 금지)
#
# =============================================================================

# -----------------------------------------------------------------------------
# 공통
# -----------------------------------------------------------------------------
NODE_ENV=development

FRONTEND_PORT=5173
BACKEND_PORT=4000

FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend → frontend/.env
# -----------------------------------------------------------------------------
# VITE_* 는 Vite가 빌드·dev 시 브라우저 번들에 넣을 수 있습니다.
# SUPABASE_SECRET_KEY, service_role key는 frontend/.env · VITE_* 에 넣지 마세요.

VITE_API_BASE_URL=http://localhost:4000

VITE_SUPABASE_URL=https://zfaxwhdiegqjajmactic.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_hM4zffrrbCxjibUy5bmcHQ_FDt8Gflj

# -----------------------------------------------------------------------------
# Backend → backend/.env
# -----------------------------------------------------------------------------
# PORT 는 BACKEND_PORT 와 동일하게 설정합니다.

# PORT=4000
# FRONTEND_ORIGIN=http://localhost:5173

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# server-only: backend/.env · 서버 코드 전용. frontend/.env · VITE_* · docker-compose environment 금지
SUPABASE_SECRET_KEY=your-supabase-secret-key
