# =============================================================================
# Frontend — 환경 변수 템플릿
# 사용법: cp frontend/.env.example frontend/.env 후 Dashboard 값으로 교체
# 실제 secret 값은 Git에 커밋하지 마세요.
# =============================================================================
#
# Supabase Dashboard → Project Settings → API
#   Project URL      → VITE_SUPABASE_URL
#   Publishable key  → VITE_SUPABASE_PUBLISHABLE_KEY (권장)
#   anon public key  → VITE_SUPABASE_ANON_KEY (fallback)
#
# VITE_* 만 사용합니다.
# SUPABASE_SECRET_KEY, service_role key는 frontend/.env · VITE_* 에 넣지 마세요.
# 상세: docs/04-security/api-key-policy.md
#
# =============================================================================

VITE_API_BASE_URL=http://localhost:4000

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# publishable key 대신 anon key를 쓸 경우 (둘 중 하나만 설정):
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
