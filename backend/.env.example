# =============================================================================
# Backend — 환경 변수 템플릿
# 사용법: cp .env.example .env 후 Dashboard 값으로 교체
# 실제 secret 값은 Git에 커밋하지 마세요.
# =============================================================================
#
# Supabase Dashboard → Project Settings → API
#   Project URL     → SUPABASE_URL
#   anon public key → SUPABASE_ANON_KEY
#   service_role    → SUPABASE_SERVICE_ROLE_KEY (backend 전용, 프론트·VITE_* 금지)
#
# =============================================================================

PORT=4000

# CORS (docker-compose / Express)
FRONTEND_ORIGIN=http://localhost:5173

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# server-only: API·서버 코드에서만 사용. frontend/.env · VITE_* · 브라우저 번들 금지
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
