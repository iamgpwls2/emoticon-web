# =============================================================================
# Backend — 환경 변수 템플릿
# 사용법: cp backend/.env.example backend/.env 후 Dashboard 값으로 교체
# 실제 secret 값은 Git에 커밋하지 마세요.
# =============================================================================
#
# Supabase Dashboard → Project Settings → API
#   Project URL      → SUPABASE_URL
#   Publishable key  → SUPABASE_PUBLISHABLE_KEY (권장)
#   anon public key  → SUPABASE_ANON_KEY (fallback, env.js와 동일 용도)
#   Secret key       → SUPABASE_SECRET_KEY (backend 전용, 프론트·VITE_* 금지)
#   service_role     → SUPABASE_SERVICE_ROLE_KEY (SUPABASE_SECRET_KEY와 동일, fallback)
#
# 상세: docs/04-security/api-key-policy.md
#
# =============================================================================

PORT=4000

# CORS (docker-compose / Express)
FRONTEND_ORIGIN=http://localhost:5173

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# server-only: API·서버 코드에서만 사용. frontend/.env · VITE_* · 브라우저 번들 금지
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Supabase Storage — 이미지 업로드 버킷 (Dashboard → Storage)
SUPABASE_UPLOAD_BUCKET=user-uploads

# -----------------------------------------------------------------------------
# LLM (backend 전용 — frontend/.env · VITE_* · 브라우저 번들 금지)
# -----------------------------------------------------------------------------
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o-mini

# anon / service_role 이름을 쓰는 경우 (위와 동일 키, 둘 중 한 세트만 설정):
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
